# SlopArena MasterServer — Environment Variables
# Copy to .env and fill in your values (DO NOT commit .env!)

# PostgreSQL connection
# Format: Host=localhost;Port=5432;Database=sloparena;Username=postgres;Password=yourpassword
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=sloparena;Username=postgres;Password=changeme

# JWT signing key — generate with: openssl rand -base64 64
Jwt__Secret=generate-a-long-random-string-here-min-32-chars

# Steam API (optional for now)
Steam__ApiKey=
